                <Rule name="Wann trat(en) diese starke(n) Blutung(en) letztmalig auf?" path="/items[at0005]"/>
            </Items>
            <Items archetype_id="openEHR-EHR-CLUSTER.acribis_follow_up_tia.v0" max="1" path="/data[at0001]/events[at0002]/data[at0003]/items[at0013]" xsi:type="tem:CLUSTER"/>
            <Items archetype_id="openEHR-EHR-CLUSTER.acribis_follow_up_heart_failure.v0" max="1" path="/data[at0001]/events[at0002]/data[at0003]/items[at0014]" xsi:type="tem:CLUSTER">
                <Rule name="Wurden der Proband/die Probandin aufgrund einer Verschlechterung seiner/ihrer Herzinsuffizienz im letzten Jahr im Krankenhaus behandelt?" path="/items[at0006]"/>
                <Rule name="Um welche weitere Herz-Kreislauf-Erkrankung handelt es sich?" path="/items[at0016]"/>
            </Items>
        </Content>
        <Content archetype_id="openEHR-EHR-OBSERVATION.eq_5d_5l.v0" max="1" path="/content" xsi:type="tem:OBSERVATION"/>
