    <definition archetype_id="openEHR-EHR-COMPOSITION.report.v1" concept_name="Bericht" name="ACRIBIS Follow-up" xmlns:tem="openEHR/v1/Template" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="tem:COMPOSITION">
        <Content archetype_id="openEHR-EHR-OBSERVATION.acribis_follow_up.v0" max="1" path="/content" xsi:type="tem:OBSERVATION">
            <Rule max="1" path="/data[at0001]/events[at0002]"/>
            <Items archetype_id="openEHR-EHR-CLUSTER.acribis_follow_up_time_period.v0" max="1" path="/data[at0001]/events[at0002]/data[at0003]/items[at0011]" xsi:type="tem:CLUSTER">
                <Rule name="Wann wurde der Herzinfarkt  diagnostiziert?" path="/items[at0005]"/>
                <Rule name="Wurde ein Schlaganfall oder eine Erkrankung der Hirngefäße diagnostiziert?" path="/items[at0006]"/>
                <Rule name="Wissen Sie, welche Art des Schlaganfalls diagnostiziert wurde?" path="/items[at0011]"/>
            </Items>
            <Items archetype_id="openEHR-EHR-CLUSTER.acribis_follow_up_death.v0" max="1" path="/data[at0001]/events[at0002]/data[at0003]/items[at0010]" xsi:type="tem:CLUSTER"/>
