			purpose = <"Zur Messung des Herzzeitvolumens">
			use = <"">
			misuse = <"Nicht zur Erfassung des Herzindex, des Schlagvolumens oder der Ejektionsfraktion.">
		>
		["en"] = <
			language = <[ISO_639-1::en]>
			purpose = <"To record cardiac output ">
