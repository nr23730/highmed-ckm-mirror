						}
					}
					allow_archetype CLUSTER[at0178] occurrences matches {0..1} matches {    -- Presentation method details
						include
							archetype_id/value matches {/openEHR-EHR-CLUSTER\.device\.v1/}
					}
					ELEMENT[at0093] matches {    -- Presented sensory modalities
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0094,    -- Auditory test
									at0095,    -- Audiovisual test
									at0096]    -- Visual test
								}
							}
						}
					}
					ELEMENT[at0064] occurrences matches {0..1} matches {    -- Response set
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0065,    -- Open set
									at0066]    -- Closed set
								}
