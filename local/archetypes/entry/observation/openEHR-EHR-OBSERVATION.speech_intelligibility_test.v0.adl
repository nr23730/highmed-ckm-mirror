								value matches {
									C_DV_QUANTITY <
										property = <[openehr::497]>
										list = <
											["1"] = <
												units = <"deg">
												magnitude = <|0.0..360.0|>
											>
										>
									>
								}
							}
							ELEMENT[at0218] occurrences matches {0..1} matches {    -- Elevation
								value matches {
									C_DV_QUANTITY <
										property = <[openehr::497]>
										list = <
											["1"] = <
												units = <"deg">
												magnitude = <|0.0..360.0|>
											>
										>

										assumed_value = <
											units = <"deg">
											magnitude = <0.0>
											precision = <-1>
										>
									>
								}
							}
							ELEMENT[at0140] occurrences matches {0..1} matches {    -- Noise stimulus details
								value matches {
									DV_TEXT matches {*}
								}
							}
						}
					}
					ELEMENT[at0212] occurrences matches {0..1} matches {    -- Directionality characteristics
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0213,    -- Diotic
									at0214,    -- Dichotic
									at0215]    -- Virtual acoustics
								}
							}
						}
					}
					CLUSTER[at0258] occurrences matches {0..1} matches {    -- Masking
						items cardinality matches {1..*; unordered} matches {
							ELEMENT[at0271] occurrences matches {0..1} matches {    -- Type of masking stimulus
								value matches {
									DV_CODED_TEXT matches {
										defining_code matches {
											[local::at0272]    -- White noise
										}
									}
									DV_TEXT matches {*}
								}
							}
							ELEMENT[at0279] occurrences matches {0..1} matches {    -- Presentation method
								value matches {
