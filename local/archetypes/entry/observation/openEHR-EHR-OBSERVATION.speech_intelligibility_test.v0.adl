									DV_TEXT matches {*}
								}
							}
							allow_archetype CLUSTER[at0270] occurrences matches {0..1} matches {    -- Presentation method details
								include
									archetype_id/value matches {/openEHR-EHR-CLUSTER\.device\.v1/}
							}
						}
					}
					ELEMENT[at0181] occurrences matches {0..1} matches {    -- Test environment
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0182,    -- Sound treated room
									at0183,    -- Non-sound treated room
									at0184]    -- Free-field
								}
							}
