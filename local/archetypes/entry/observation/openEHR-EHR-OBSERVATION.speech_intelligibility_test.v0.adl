					}
					ELEMENT[at0172] occurrences matches {0..1} matches {    -- Presentation method
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0173,    -- Loudspeaker
									at0174,    -- Insert earphone
									at0175,    -- Headphone
									at0176,    -- Direct streaming to sound processor
									at0177]    -- Live voice
								}
							}
