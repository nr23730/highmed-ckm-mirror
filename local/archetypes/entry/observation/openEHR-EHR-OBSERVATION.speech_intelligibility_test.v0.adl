definition
	OBSERVATION[at0000] matches {    -- Speech intelligibility test
		data matches {
			HISTORY[at0001] matches {    -- Event Series
				events cardinality matches {1..*; unordered} matches {
					EVENT[at0002] occurrences matches {0..*} matches {    -- Any event
						data matches {
							ITEM_TREE[at0003] matches {    -- Tree
								items cardinality matches {0..*; unordered} matches {
									ELEMENT[at0132] matches {    -- Tested side
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0134,    -- Right ear
													at0133,    -- Left ear
													at0135]    -- Binaural
												}
											}
										}
									}
									CLUSTER[at0233] occurrences matches {0..*} matches {    -- Measurement of test list
										items cardinality matches {1..*; unordered} matches {
											ELEMENT[at0234] matches {    -- Measurement identifier
												value matches {
													DV_IDENTIFIER matches {*}
												}
											}
											ELEMENT[at0235] occurrences matches {0..1} matches {    -- Specification of test list
												value matches {
													DV_TEXT matches {*}
												}
											}
											ELEMENT[at0236] occurrences matches {0..1} matches {    -- Speech level at start
												value matches {
													C_DV_QUANTITY <
														property = <[openehr::123]>
														list = <
															["1"] = <
																units = <"dB[SPL]{SPL}">
																magnitude = <|-50.0..200.0|>
																precision = <|2|>
															>
														>
													>
												}
											}
											ELEMENT[at0237] occurrences matches {0..1} matches {    -- SNR at start
												value matches {
													C_DV_QUANTITY <
														property = <[openehr::123]>
														list = <
															["1"] = <
																units = <"dB[SPL]{SNR}">
																magnitude = <|-50.0..200.0|>
																precision = <|2|>
															>
														>
													>
												}
											}
											ELEMENT[at0238] occurrences matches {0..1} matches {    -- Speech intelligibility of test list
												value matches {
													DV_PROPORTION matches {
														numerator matches {|0.0..100.0|}
														type matches {2}
													}
												}
											}
											CLUSTER[at0239] occurrences matches {0..*} matches {    -- Measurement of test list item
												items cardinality matches {1..*; unordered} matches {
													ELEMENT[at0242] occurrences matches {0..1} matches {    -- Test list item identifier
														value matches {
															DV_TEXT matches {*}
														}
													}
													ELEMENT[at0243] matches {    -- Speech level
														value matches {
															C_DV_QUANTITY <
																property = <[openehr::123]>
																list = <
																	["1"] = <
																		units = <"dB[SPL]{SPL}">
																		magnitude = <|-50.0..200.0|>
																		precision = <|2|>
																	>
																>
															>
														}
													}
													ELEMENT[at0244] occurrences matches {0..1} matches {    -- SNR
														value matches {
															C_DV_QUANTITY <
																property = <[openehr::123]>
																list = <
																	["1"] = <
																		units = <"dB[SPL]{SNR}">
																		magnitude = <|-50.0..200.0|>
																		precision = <|2|>
																	>
																>
															>
														}
													}
													ELEMENT[at0245] matches {    -- Speech intelligibility of test list item
														value matches {
															DV_PROPORTION matches {
																numerator matches {|0.0..100.0|}
																type matches {2}
															}
														}
													}
												}
											}
											CLUSTER[at0241] occurrences matches {0..*} matches {    -- Speech recognition threshold adaptive
												items cardinality matches {1..*; unordered} matches {
													ELEMENT[at0246] matches {    -- Target speech intelligibility
														value matches {
															DV_PROPORTION matches {
																numerator matches {|0.0..100.0|; 50.0}
																type matches {2}
															}
														}
													}
													ELEMENT[at0247] matches {    -- Speech level at target
														value matches {
															C_DV_QUANTITY <
																property = <[openehr::123]>
																list = <
																	["1"] = <
																		units = <"dB[SPL]{SPL}">
																		magnitude = <|-50.0..200.0|>
																		precision = <|2|>
																	>
																>
															>
														}
													}
													ELEMENT[at0248] occurrences matches {0..1} matches {    -- SNR at target
														value matches {
															C_DV_QUANTITY <
																property = <[openehr::123]>
																list = <
																	["1"] = <
																		units = <"dB[SPL]{SNR}">
																		magnitude = <|-50.0..200.0|>
																		precision = <|2|>
																	>
																>
															>
														}
													}
													ELEMENT[at0276] occurrences matches {0..1} matches {    -- Slope at target
														value matches {
															C_DV_QUANTITY <
																property = <[openehr::755]>
																list = <
																	["1"] = <
																		units = <"[arb'U]{%}/dB">
																		magnitude = <|0.0..100.0|>
																		precision = <|2|>
																	>
																>
															>
														}
													}
												}
											}
										}
									}
									CLUSTER[at0017] occurrences matches {0..*} matches {    -- Speech recognition threshold derived
										items cardinality matches {1..*; unordered} matches {
											ELEMENT[at0194] matches {    -- Target speech intelligibility
												value matches {
													DV_PROPORTION matches {
														type matches {2,3}
													}
												}
											}
											ELEMENT[at0250] matches {    -- Speech level at target
												value matches {
													C_DV_QUANTITY <
														property = <[openehr::123]>
														list = <
															["1"] = <
																units = <"dB[SPL]{SPL}">
																magnitude = <|-50.0..200.0|>
																precision = <|2|>
															>
														>
													>
												}
											}
											ELEMENT[at0278] occurrences matches {0..1} matches {    -- SNR at target
												value matches {
													C_DV_QUANTITY <
														property = <[openehr::123]>
														list = <
															["1"] = <
																units = <"dB[SPL]{SNR}">
																magnitude = <|-50.0..200.0|>
																precision = <|2|>
															>
														>
													>
												}
											}
											ELEMENT[at0277] occurrences matches {0..1} matches {    -- Slope at target
												value matches {
													C_DV_QUANTITY <
														property = <[openehr::755]>
														list = <
															["1"] = <
																units = <"[arb'U]{%}/dB">
																magnitude = <|0.0..100.0|>
																precision = <|2|>
															>
														>
													>
												}
											}
											ELEMENT[at0201] occurrences matches {0..1} matches {    -- SRT calculation method
												value matches {
													DV_TEXT matches {*}
												}
											}
											ELEMENT[at0203] occurrences matches {0..*} matches {    -- Related measurements
												value matches {
													DV_IDENTIFIER matches {*}
												}
											}
										}
									}
									ELEMENT[at0022] occurrences matches {0..1} matches {    -- Overall comment
										value matches {
											DV_TEXT matches {*}
										}
									}
									allow_archetype CLUSTER[at0163] occurrences matches {0..1} matches {    -- No test result
										include
											archetype_id/value matches {/openEHR-EHR-CLUSTER\.exclusion_exam\.v1/}
									}
									ELEMENT[at0200] matches {    -- Training condition
										value matches {
											DV_BOOLEAN matches {*}
										}
									}
								}
							}
						}
						state matches {
							ITEM_TREE[at0023] matches {    -- Tree
								items cardinality matches {0..*; unordered} matches {
									CLUSTER[at0164] occurrences matches {0..1} matches {    -- Hearing device during test
										items cardinality matches {1..*; unordered} matches {
											allow_archetype CLUSTER[at0165] matches {    -- Hearing device
												include
													archetype_id/value matches {/openEHR-EHR-CLUSTER\.device\.v1/}
											}
											ELEMENT[at0166] matches {    -- Side of hearing device
												value matches {
													DV_CODED_TEXT matches {
														defining_code matches {
															[local::
															at0167,    -- Left
															at0168]    -- Right
														}
													}
												}
											}
											ELEMENT[at0169] occurrences matches {0..1} matches {    -- Comment
												value matches {
													DV_TEXT matches {*}
												}
											}
										}
									}
									ELEMENT[at0170] occurrences matches {0..1} matches {    -- Confounding factors
										value matches {
											DV_TEXT matches {*}
										}
									}
									ELEMENT[at0153] occurrences matches {0..1} matches {    -- Language proficiency of the listener
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0154,    -- Native
													at0155,    -- Fluent
													at0156,    -- Basic
													at0157]    -- None
												}
											}
											DV_TEXT matches {*}
										}
									}
								}
							}
						}
					}
				}
			}
		}
		protocol matches {
			ITEM_TREE[at0032] matches {    -- Tree
				items cardinality matches {0..*; unordered} matches {
					ELEMENT[at0145] occurrences matches {0..1} matches {    -- Test name
						value matches {
							DV_TEXT matches {*}
						}
					}
					ELEMENT[at0251] occurrences matches {0..1} matches {    -- Test language
						value matches {
							DV_TEXT matches {*}
						}
					}
					ELEMENT[at0054] occurrences matches {0..1} matches {    -- Voice type
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0055,    -- Female
									at0056,    -- Male
									at0204,    -- Synthetic female
									at0205,    -- Synthetic male
									at0208,    -- Child
									at0209]    -- Synthetic child
								}
							}
						}
					}
					ELEMENT[at0101] occurrences matches {0..1} matches {    -- Announcement
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0102,    -- Sentence
									at0103,    -- Non-speech auditory cue
									at0104,    -- Visual cue
									at0105]    -- Without
								}
							}
						}
					}
					ELEMENT[at0257] matches {    -- Test in background noise
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0285,    -- Quiet
									at0286]    -- Noise
								}
							}
						}
					}
					ELEMENT[at0196] occurrences matches {0..1} matches {    -- Fixed stimulus
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0197,    -- Speech
									at0198]    -- Noise
								}
							}
						}
					}
					CLUSTER[at0107] matches {    -- Level control
						items cardinality matches {1..*; unordered} matches {
							ELEMENT[at0227] occurrences matches {1..*} matches {    -- Adaptive procedure name
								value matches {
									DV_CODED_TEXT matches {
										defining_code matches {
											[local::
											at0228,    -- One-up one-down
											at0229]    -- Brand & Kollmeier (2002)
										}
									}
									DV_TEXT matches {*}
								}
							}
							ELEMENT[at0090] occurrences matches {0..1} matches {    -- Step size
								value matches {
									C_DV_QUANTITY <
										property = <[openehr::123]>
										list = <
											["1"] = <
												units = <"dB">
												precision = <|0|>
											>
										>
									>
								}
							}
							ELEMENT[at0231] occurrences matches {0..1} matches {    -- Adaptive procedure details
								value matches {
									DV_TEXT matches {*}
								}
							}
						}
					}
					CLUSTER[at0219] matches {    -- Speech stimulus
						items cardinality matches {1..*; unordered} matches {
							ELEMENT[at0070] matches {    -- Type of speech stimulus
								value matches {
									DV_CODED_TEXT matches {
										defining_code matches {
											[local::
											at0071,    -- Nonsense syllable
											at0072,    -- Nonsense CVC
											at0073,    -- Nonsense word
											at0074,    -- Monosyllabic word
											at0075,    -- Spondee word
											at0076,    -- Trochee word
											at0137,    -- Matrix sentence
											at0138,    -- Meaningful sentence
											at0099,    -- Number
											at0100,    -- Digit triplet
											at0179]    -- Phoneme
										}
									}
									DV_TEXT matches {*}
								}
							}
							ELEMENT[at0225] occurrences matches {0..1} matches {    -- Azimuth
								value matches {
									C_DV_QUANTITY <
										property = <[openehr::497]>
										list = <
											["1"] = <
												units = <"deg">
												magnitude = <|0.0..360.0|>
											>
										>
									>
								}
							}
							ELEMENT[at0226] occurrences matches {0..1} matches {    -- Elevation
								value matches {
									C_DV_QUANTITY <
										property = <[openehr::497]>
										list = <
											["1"] = <
												units = <"deg">
												magnitude = <|0.0..360.0|>
											>
										>

										assumed_value = <
											units = <"deg">
											magnitude = <0.0>
											precision = <-1>
										>
									>
								}
							}
						}
					}
					CLUSTER[at0216] occurrences matches {0..*} matches {    -- Noise stimulus
						items cardinality matches {1..*; unordered} matches {
							ELEMENT[at0040] matches {    -- Type of noise stimulus
								value matches {
									DV_CODED_TEXT matches {
										defining_code matches {
											[local::
											at0041,    -- White noise
											at0042,    -- Speech spectrum noise
											at0043,    -- Multitalker babble
											at0044]    -- Alternate speaker
										}
