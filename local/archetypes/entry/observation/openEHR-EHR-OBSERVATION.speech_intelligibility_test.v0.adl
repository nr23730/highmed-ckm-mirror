						}
					}
					ELEMENT[at0060] occurrences matches {0..1} matches {    -- Response mode
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0171,    -- Computer
									at0061,    -- Vocal
									at0062,    -- Picture pointing
									at0063,    -- Written response alternatives
									at0086]    -- Concrete object pointing
								}
							}
						}
					}
					ELEMENT[at0113] occurrences matches {0..1} matches {    -- Scoring method
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0114,    -- Word scoring
									at0115,    -- Sentence scoring
									at0116,    -- Phoneme scoring
									at0117]    -- Keyword scoring
								}
							}
						}
					}
				}
			}
		}
	}


ontology
	terminologies_available = <"Common Languages", ...>
	term_definitions = <
		["en"] = <
			items = <
				["at0000"] = <
					text = <"Speech intelligibility test">
					description = <"Record of results from an audiological speech intelligibility test conducted for the purpose of assessing speech recognition, speech discrimination, or speech intelligibility.">
				>
				["at0001"] = <
					text = <"Event Series">
					description = <"@ internal @">
				>
				["at0002"] = <
					text = <"Any event">
					description = <"Default, unspecified point in time or interval event which may be explicitly defined in a template or at run-time.">
				>
				["at0003"] = <
					text = <"Tree">
					description = <"@ internal @">
				>
				["at0017"] = <
					text = <"Speech recognition threshold derived">
					description = <"The estimated speech recognition threshold (SRT) derived from several 'Measurements of test lists'. ">
					comment = <"Not applicable for adaptive level measurements. ">
				>
				["at0022"] = <
					text = <"Overall comment">
					description = <"Additional narrative about the speech intelligibility measurement not captured in other fields.">
				>
				["at0023"] = <
					text = <"Tree">
					description = <"@ internal @">
				>
				["at0032"] = <
					text = <"Tree">
					description = <"@ internal @">
				>
				["at0040"] = <
					text = <"Type of noise stimulus">
					description = <"The type of noise stimulus used during speech in noise testing. Further details can be given in 'Noise type details'.">
					comment = <"Not applicable for speech in quiet tests.">
				>
				["at0041"] = <
					text = <"White noise">
					description = <"Noise that has the same power at all frequencies (i.e., a flat power spectrum).">
				>
				["at0042"] = <
					text = <"Speech spectrum noise">
					description = <"Noise spectrum that approximates the average long term speech spectrum.">
				>
				["at0043"] = <
					text = <"Multitalker babble">
					description = <"A recording of the voices of many people who are talking simultaneously, resulting in an unintelligible babble.">
				>
				["at0044"] = <
					text = <"Alternate speaker">
					description = <"The masker is a single person speaking and this speaker is different to the speaker used for the test stimulus.">
				>
				["at0054"] = <
					text = <"Voice type">
					description = <"The voice type (sex) of the speech stimulus.">
				>
				["at0055"] = <
					text = <"Female">
					description = <"Stimuli presented by a female talker.">
				>
				["at0056"] = <
					text = <"Male">
					description = <"Stimuli presented by a male talker.">
				>
				["at0060"] = <
					text = <"Response mode">
					description = <"The mode used to enter or record the response.">
				>
				["at0061"] = <
					text = <"Vocal">
					description = <"The response is given verbally.">
				>
				["at0062"] = <
					text = <"Picture pointing">
					description = <"The response is given by pointing to a picture of the stimulus item.">
				>
				["at0063"] = <
					text = <"Written response alternatives">
					description = <"The response is given by pointing to written text corresponding to the stimulus item.">
				>
				["at0064"] = <
					text = <"Response set">
					description = <"The type of the response set.">
				>
				["at0065"] = <
					text = <"Open set">
					description = <"The response set is unlimited.">
				>
				["at0066"] = <
					text = <"Closed set">
					description = <"The response set is limited.">
				>
				["at0070"] = <
					text = <"Type of speech stimulus">
					description = <"The type of speech stimulus used.">
				>
				["at0071"] = <
					text = <"Nonsense syllable">
					description = <"A consonant-vowel (CV) or CCV or VC or VCC item that is not a real word but is phonotactically correct.">
				>
				["at0072"] = <
					text = <"Nonsense CVC">
					description = <"Nonsense word comprising a consonant, then a vowel, then a final consonant, for example, \"wub\" or \"yat\".">
				>
				["at0073"] = <
					text = <"Nonsense word">
					description = <"A speech stimulus that is not a real word but is phonotactically correct.">
				>
				["at0074"] = <
					text = <"Monosyllabic word">
					description = <"A word comprised of a single syllable. For example, 'green'.">
				>
				["at0075"] = <
					text = <"Spondee word">
					description = <"A word comprised of 2 syllables with equal stress on each syllable. For example, 'sunshine'.">
				>
				["at0076"] = <
					text = <"Trochee word">
					description = <"A word that is comprised of two syllables with stress on the first syllable. For example 'bucket'.">
				>
				["at0086"] = <
					text = <"Concrete object pointing">
					description = <"The response is given by pointing to a 3-dimensional object.">
				>
				["at0090"] = <
					text = <"Step size">
					description = <"The stepsize of level changes.">
				>
				["at0093"] = <
					text = <"Presented sensory modalities">
					description = <"The method used to present the speech test stimulus.">
					comment = <"For example: a visual stimulus can be used to test lip reading skills.">
				>
				["at0094"] = <
					text = <"Auditory test">
					description = <"An auditory stimulus is presented to the test subject.">
				>
				["at0095"] = <
					text = <"Audiovisual test">
					description = <"A combination of auditory and visual stimuli are presented to the test subject.">
				>
				["at0096"] = <
					text = <"Visual test">
					description = <"A visual stimulus is presented to the test subject.">
				>
				["at0099"] = <
					text = <"Number">
					description = <"A number.">
				>
				["at0100"] = <
					text = <"Digit triplet">
					description = <"A sequence of three digits.">
				>
				["at0101"] = <
					text = <"Announcement">
					description = <"The type of announcement before presenting the speech stimulus.">
				>
				["at0102"] = <
					text = <"Sentence">
					description = <"An announcement sentence is presented prior to each stimulus.">
				>
				["at0103"] = <
					text = <"Non-speech auditory cue">
					description = <"A non-speech auditory announcement is presented prior to each stimulus (e.g., beep).">
				>
				["at0104"] = <
					text = <"Visual cue">
					description = <"A visual cue is presented prior to each stimulus (e.g., flashing light).">
				>
				["at0105"] = <
					text = <"Without">
					description = <"No announcement prior to each stimulus.">
				>
				["at0107"] = <
					text = <"Level control">
					description = <"The description of the adaptive level control procedure.">
					comment = <"Applicable for adaptive measurements.">
				>
				["at0113"] = <
					text = <"Scoring method">
					description = <"The scoring method used.">
				>
				["at0114"] = <
					text = <"Word scoring">
					description = <"Counting correct words in responses.">
				>
				["at0115"] = <
					text = <"Sentence scoring">
					description = <"Counting correct sentences in responses.">
				>
				["at0116"] = <
					text = <"Phoneme scoring">
					description = <"Counting correct phonemes in responses.">
				>
				["at0117"] = <
					text = <"Keyword scoring">
					description = <"Counting correct keywords in responses.">
				>
				["at0132"] = <
					text = <"Tested side">
					description = <"Identification of the tested ear(s).">
				>
				["at0133"] = <
					text = <"Left ear">
					description = <"The test stimuli were presented to the left ear.">
				>
				["at0134"] = <
					text = <"Right ear">
					description = <"The test stimuli were presented to the right ear.">
				>
				["at0135"] = <
					text = <"Binaural">
					description = <"The test stimuli were presented to the both ears simultaneously.">
				>
				["at0137"] = <
					text = <"Matrix sentence">
					description = <"Sentence composed of a fixed syntactical structure without meaningful context.">
				>
				["at0138"] = <
					text = <"Meaningful sentence">
					description = <"A grammatical unit of one or more words that expresses an independent statement, question, request, command, exclamation, everyday-sentences etc.">
				>
				["at0140"] = <
					text = <"Noise stimulus details">
					description = <"Details on signals used as noise in 'Type of noise stimulus', e.g., name of established noise, number of talkers included in a babble noise, or other specific characteristics.">
					comment = <"Not applicable for speech in quiet tests.">
				>
				["at0145"] = <
					text = <"Test name">
					description = <"The name of the conducted speech test.">
					comment = <"Use published name (including a reference) if possible.">
				>
				["at0153"] = <
					text = <"Language proficiency of the listener">
					description = <"Language proficiency in broad categories.">
				>
				["at0154"] = <
					text = <"Native">
					description = <"Listener is native speaker in the presented test language.">
				>
				["at0155"] = <
					text = <"Fluent">
					description = <"Listener is fluent in the presented test language.">
				>
				["at0156"] = <
					text = <"Basic">
					description = <"Listener has only basic proficiency in the presented test language.">
				>
				["at0157"] = <
					text = <"None">
					description = <"Listener has no proficiency in the presented test language.">
				>
				["at0163"] = <
					text = <"No test result">
					description = <"Details to explicitly record that this examination was not performed.">
				>
				["at0164"] = <
					text = <"Hearing device during test">
					description = <"Information about hearing device use during the speech test.">
				>
				["at0165"] = <
					text = <"Hearing device">
					description = <"Details of the hearing device used.">
					comment = <"For example: hearing aid or cochlear implant as type of device.">
				>
				["at0166"] = <
					text = <"Side of hearing device">
					description = <"Identification of the side where the hearing device is worn during the test.">
				>
				["at0167"] = <
					text = <"Left">
					description = <"The hearing device is worn at the left side.">
				>
				["at0168"] = <
					text = <"Right">
					description = <"The hearing device is worn at the right side.">
				>
				["at0169"] = <
					text = <"Comment">
					description = <"Additional information about the hearing device that is not captured in 'Hearing device' or 'Side of hearing device'.">
					comment = <"For example: information about hearing device settings.">
				>
				["at0170"] = <
					text = <"Confounding factors">
					description = <"Additional issues or factors that may impact the speech test, not captured in other fields.">
					comment = <"For example: medication or noise exposure prior to test.">
				>
				["at0171"] = <
					text = <"Computer">
					description = <"The response is entered via a software interface.">
				>
				["at0172"] = <
					text = <"Presentation method">
					description = <"The method used to present the test stimuli.">
				>
				["at0173"] = <
					text = <"Loudspeaker">
					description = <"The stimulus is presented via a loudspeaker.">
				>
				["at0174"] = <
					text = <"Insert earphone">
					description = <"The stimulus is presented via insert earphones.">
				>
				["at0175"] = <
					text = <"Headphone">
					description = <"The stimulus is presented via external headphones - either circumaural or supraaural.">
				>
				["at0176"] = <
					text = <"Direct streaming to sound processor">
					description = <"The stimulus is directly streamed to the sound processor of a hearing device.">
				>
				["at0177"] = <
					text = <"Live voice">
					description = <"The stimulus is spoken.">
				>
				["at0178"] = <
					text = <"Presentation method details">
					description = <"Details of device used to present test stimulus as specified in 'Presentation method'.">
					comment = <"For example: type of headphone or speaker.">
				>
				["at0179"] = <
					text = <"Phoneme">
					description = <"A phoneme.">
				>
				["at0181"] = <
					text = <"Test environment">
					description = <"The environment in which the speech test is administered.">
				>
				["at0182"] = <
					text = <"Sound treated room">
					description = <"Test environment that has been treated acoustically.">
				>
				["at0183"] = <
					text = <"Non-sound treated room">
					description = <"Test environment that has not been treated acoustically.">
				>
				["at0184"] = <
					text = <"Free-field">
					description = <"Room with free-field characteristics, also called 'anechoic room'.">
				>
				["at0185"] = <
					text = <"Test environment details">
					description = <"Additional details of 'Test environment'.">
					comment = <"For example: specific audiometric booth or a free text description of the room's sound treatment.">
				>
				["at0194"] = <
					text = <"Target speech intelligibility">
					description = <"The target percentage of the speech intelligibility measurement.">
					comment = <"For example: 50%.">
				>
				["at0196"] = <
					text = <"Fixed stimulus">
					description = <"To indicate for which stimulus (speech or noise) the level is kept constant during the measurement.">
					comment = <"Only applicable for speech in noise tests measured adaptively.">
				>
				["at0197"] = <
					text = <"Speech">
					description = <"The speech level is kept constant during the test.">
				>
				["at0198"] = <
					text = <"Noise">
					description = <"The noise level is kept constant during the test.">
				>
				["at0200"] = <
					text = <"Training condition">
					description = <"Indicates if the measurement was performed for training or test purposes.">
					comment = <"Applicable if the speech intelligibility test requires training, for example: Matrix test. ">
				>
				["at0201"] = <
					text = <"SRT calculation method">
					description = <"The description of how the SRT is derived from 'Measurements of test lists'. ">
				>
				["at0203"] = <
					text = <"Related measurements">
					description = <"The identifiers 'Measurements of test lists' from which the SRT is derived, as specified in 'Measurement identifier'. ">
				>
				["at0204"] = <
					text = <"Synthetic female">
					description = <"Stimuli presented by a synthetically generated female voice.">
				>
				["at0205"] = <
					text = <"Synthetic male">
					description = <"Stimuli presented by a synthetically generated male voice.">
				>
				["at0208"] = <
					text = <"Child">
					description = <"Stimuli presented by a child.">
				>
				["at0209"] = <
					text = <"Synthetic child">
					description = <"Stimuli presented by a synthetically generated children voice.">
				>
				["at0212"] = <
					text = <"Directionality characteristics">
					description = <"Only applicable for 'Tested side' binaural.">
					comment = <"Diotic and dichotic: no virtual acoustics.">
				>
				["at0213"] = <
					text = <"Diotic">
					description = <"The same sound is presented to both ears.">
				>
				["at0214"] = <
					text = <"Dichotic">
					description = <"Different sounds are presented to both ears.">
				>
				["at0215"] = <
					text = <"Virtual acoustics">
					description = <"The sound is rendered using head-related transfer functions, enabling directionality of sound sources.">
				>
				["at0216"] = <
					text = <"Noise stimulus">
					description = <"Properties of the noise stimulus. ">
					comment = <"Can be repeated for several, directional noise stimuli, for example: competing talkers from different azimuth directions. ">
				>
				["at0217"] = <
					text = <"Azimuth">
					description = <"Azimuth angle of 'Noise stimulus'. 
">
					comment = <"Only applicable if 'Directionality characteristics' is 'Virtual acoustics'. ">
				>
				["at0218"] = <
					text = <"Elevation">
					description = <"Elevation angle of 'Noise stimulus'.">
					comment = <"Only applicable if 'Directionality characteristics' is 'Virtual acoustics'. ">
				>
				["at0219"] = <
					text = <"Speech stimulus">
					description = <"Properties of the speech stimulus. ">
				>
				["at0225"] = <
					text = <"Azimuth">
					description = <"Azimuth angle of 'Speech stimulus'. 
">
					comment = <"Only applicable if 'Directionality characteristics' is 'Virtual acoustics'. ">
				>
				["at0226"] = <
					text = <"Elevation">
					description = <"Elevation angle of 'Speech stimulus'.">
					comment = <"Only applicable if 'Directionality characteristics' is 'Virtual acoustics'. ">
				>
				["at0227"] = <
					text = <"Adaptive procedure name">
					description = <"The name of the adaptive level control procedure. ">
				>
				["at0228"] = <
					text = <"One-up one-down">
					description = <"Level control according to one-up one-down procedure (e.g., Levitt, 1971).">
				>
				["at0229"] = <
					text = <"Brand & Kollmeier (2002)">
					description = <"Level control according to Brand & Kollmeier (2002).">
				>
				["at0231"] = <
					text = <"Adaptive procedure details">
					description = <"Additional details about adaptive level control procedure. ">
				>
				["at0233"] = <
					text = <"Measurement of test list">
					description = <"Results obtained with one test list. ">
					comment = <"Applicable to both adaptive and fixed level/SNR measurements. ">
				>
				["at0234"] = <
					text = <"Measurement identifier">
					description = <"The identifier to group several 'Measurements of test list' based on which a 'SRT derived' is estimated. ">
					comment = <"Test lists used together can be grouped using 'Related measurements' in 'SRT derived'.">
				>
				["at0235"] = <
					text = <"Specification of test list">
					description = <"The name or number of the used test list.">
					comment = <"If applicable for the specific test, for example: Matrix sentence test or German Freiburg monosyllabic speech test. ">
				>
				["at0236"] = <
					text = <"Speech level at start">
					description = <"The start level of the presented speech stimulus at the beginning of the test list. ">
					comment = <"Applicable if the presented level at the beginning of a test list is not captured in the levels stored per test list item. 
">
				>
				["at0237"] = <
					text = <"SNR at start">
					description = <"The signal-to-noise ratio at the beginning of the test list. ">
					comment = <"Applicable if the presented level at the beginning of a test list is not captured in the levels stored per test list item. Only applicable for measurements in noise. ">
				>
				["at0238"] = <
					text = <"Speech intelligibility of test list">
					description = <"The speech intelligibility of the test list.  ">
					comment = <"Only applicable for fixed level/SNR measurements (speech and noise level are constant during the complete test list). ">
				>
				["at0239"] = <
					text = <"Measurement of test list item">
					description = <"To record speech intelligibility results per test list item (for example: word, sentence).">
				>
				["at0241"] = <
					text = <"Speech recognition threshold adaptive">
					description = <"The estimated speech recognition threshold (SRT) resulting from an adaptive measurement. ">
					comment = <"Not applicable for fixed level measurements. ">
				>
				["at0242"] = <
					text = <"Test list item identifier">
					description = <"The name, description, or testing order of the test list item. ">
				>
				["at0243"] = <
					text = <"Speech level">
					description = <"The level of the presented speech stimulus (test list item). ">
				>
				["at0244"] = <
					text = <"SNR">
					description = <"The signal-to-noise ratio of the test list item.">
				>
				["at0245"] = <
					text = <"Speech intelligibility of test list item">
					description = <"The speech intelligibility of the test list item (for example: word, sentence). ">
				>
				["at0246"] = <
					text = <"Target speech intelligibility">
					description = <"The target percentage of the speech intelligibility measurement.">
					comment = <"For example: 50%.">
				>
				["at0247"] = <
					text = <"Speech level at target">
					description = <"The level of the speech stimulus required to achieve the target speech intelligibility.">
				>
				["at0248"] = <
					text = <"SNR at target">
					description = <"The signal-to-noise ratio required to achieve the target speech intelligibility.">
					comment = <"Only applicable for measurements in noise. ">
				>
				["at0250"] = <
					text = <"Speech level at target">
					description = <"The level of the speech stimulus required to achieve the target speech intelligibility.">
				>
				["at0251"] = <
					text = <"Test language">
					description = <"The language of the speech stimulus.">
					comment = <"Add language terminology at template level to include all coded options.">
				>
				["at0257"] = <
					text = <"Test in background noise">
					description = <"To describe if the speech intelligibility test is conducted in noise or in quiet.">
				>
				["at0258"] = <
					text = <"Masking">
					description = <"The description of the signal used for masking (at the contralateral ear) if applicable, for example: in case of asymmetric hearing loss and monaural (aided) measurements. ">
				>
				["at0270"] = <
					text = <"Presentation method details">
					description = <"Details of device used to present test stimulus as specified in 'Presentation method'.">
					comment = <"For example: type of headphone or speaker.">
				>
				["at0271"] = <
					text = <"Type of masking stimulus">
					description = <"The type of masking stimulus used during speech in noise testing. ">
				>
				["at0272"] = <
					text = <"White noise">
					description = <"Noise that has the same power at all frequencies (i.e., a flat power spectrum).">
				>
				["at0276"] = <
					text = <"Slope at target">
					description = <"The slope of the psychometric function at the target intelligibility. ">
				>
				["at0277"] = <
					text = <"Slope at target">
					description = <"The slope of the psychometric function at the target intelligibility. ">
				>
				["at0278"] = <
					text = <"SNR at target">
					description = <"The signal-to-noise ratio required to achieve the target speech intelligibility.">
					comment = <"Only applicable for measurements in noise. ">
				>
				["at0279"] = <
					text = <"Presentation method">
					description = <"The method used to present the test stimuli.">
				>
				["at0281"] = <
					text = <"Insert earphone">
					description = <"The stimulus is presented via insert earphones.">
				>
				["at0282"] = <
					text = <"Headphone">
					description = <"The stimulus is presented via external headphones - either circumaural or supraaural.">
				>
				["at0283"] = <
					text = <"Direct streaming to sound processor">
					description = <"The stimulus is directly streamed to the sound processor of a hearing device.">
				>
				["at0285"] = <
					text = <"Quiet">
					description = <"The speech test is conducted without background noise.">
				>
				["at0286"] = <
					text = <"Noise">
					description = <"The speech test is conducted in background noise.">
				>
			>
		>
	>
