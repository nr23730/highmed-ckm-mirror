definition
	CLUSTER[at0000] matches {    -- ACRIBIS Follow-up severe bleeding
		items cardinality matches {1..*; unordered} matches {
			ELEMENT[at0001] occurrences matches {0..1} matches {    -- Did a severe spontaneous bleeding event occur that was diagnosed and required medical treatment?
				value matches {
					1|[local::at0002],
					2|[local::at0003],
					3|[local::at0004]
				}
			}
			ELEMENT[at0005] occurrences matches {0..1} matches {    -- When did this/these severe bleeding event(s) last occur?
				value matches {
					DV_DATE_TIME matches {*}
				}
			}
		}
	}


